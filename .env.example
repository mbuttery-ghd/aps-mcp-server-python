# ============================================================
# APS Application Credentials (required by all three servers)
# ============================================================
APS_CLIENT_ID=your_aps_client_id
APS_CLIENT_SECRET=your_aps_client_secret

# ============================================================
# Secure Service Account credentials (mcp_server_ssa only)
# ============================================================
# The unique identifier of the Secure Service Account.
APS_SSA_ID=your_ssa_service_account_id

# The key pair ID registered with the service account.
APS_SSA_KEY_ID=your_ssa_key_pair_id

# RSA private key encoded as a single-line Base64 string.
# Generate with: base64 -w 0 private_key.pem   (Linux)
#            or: base64 -i private_key.pem       (macOS)
APS_SSA_KEY_BASE64=base64_encoded_rsa_private_key_pem
